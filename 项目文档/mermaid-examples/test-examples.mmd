%% ========================================
%% 示例 9: 复杂决策树
%% ========================================
flowchart TD
    Start([开始]) --> Q1{问题1}

    Q1 -->|A| Q2A{问题2A}
    Q1 -->|B| Q2B{问题2B}
    Q1 -->|C| Result1[结果1]

    Q2A -->|A1| Q3A1{问题3A1}
    Q2A -->|A2| Result2[结果2]

    Q2B -->|B1| Result3[结果3]
    Q2B -->|B2| Q3B2{问题3B2}

    Q3A1 -->|A1a| Result4[结果4]
    Q3A1 -->|A1b| Result5[结果5]

    Q3B2 -->|B2a| Result6[结果6]
    Q3B2 -->|B2b| Result7[结果7]

    Result1 & Result2 & Result3 & Result4 & Result5 & Result6 & Result7 --> End([结束])

%% ========================================
%% 示例 10: 数据处理流水线
%% ========================================
flowchart LR
    subgraph input [数据输入]
        direction TB
        File[/文件/] --> Parser[解析器]
        API[/API/] --> Parser
        DB[(数据库)] --> Parser
    end

    Parser --> Validator

    subgraph processing [数据处理]
        direction TB
        Validator{验证} -->|通过| Transform[转换]
        Validator -->|失败| ErrorLog[/错误日志/]

        Transform --> Enrich[数据增强]
        Enrich --> Aggregate[聚合]

        subgraph ml [机器学习]
            Model[模型] --> Predict[预测]
            Predict --> Score[评分]
        end

        Aggregate --> ml
    end

    subgraph output [数据输出]
        direction TB
        Score --> Cache[(缓存)]
        Score --> Storage[(存储)]
        Score --> Notify[/通知/]
    end

    ErrorLog -.-> Monitor((监控))
    processing -.-> Monitor

%% ========================================
%% 示例 11: Git 工作流
%% ========================================
flowchart TD
    Start([开始开发]) --> Clone[克隆仓库]
    Clone --> Branch[创建分支]

    Branch --> Dev{开发循环}
    Dev -->|编写代码| Code[编码]
    Code --> Test[本地测试]
    Test --> Commit[提交]
    Commit --> Dev
    Dev -->|完成| Push[推送到远程]

    Push --> PR[创建PR]

    subgraph review [代码评审]
        direction TB
        PR --> Review{评审}
        Review -->|需要修改| Changes[修改代码]
        Changes --> PR
        Review -->|通过| Approve[批准]
    end

    Approve --> Merge[合并到主分支]

    subgraph ci_cd [CI/CD]
        direction LR
        Merge --> Build[构建]
        Build --> AutoTest[自动化测试]
        AutoTest --> Deploy{部署}
        Deploy -->|测试环境| Staging[Staging]
        Deploy -->|生产环境| Production[Production]
    end

    Production --> End([完成])

%% ========================================
%% 示例 12: 用户认证流程（带样式）
%% ========================================
flowchart TB
    Start([用户访问]) --> CheckToken{检查Token}

    CheckToken -->|无Token| Login[/登录页面/]
    CheckToken -->|有Token| Validate{验证Token}

    Login --> Credentials[/输入凭证/]
    Credentials --> Auth{认证}

    Auth -->|失败| LoginFail[显示错误]
    LoginFail --> Login

    Auth -->|成功| CreateToken[生成Token]
    CreateToken --> SaveSession[(保存会话)]

    Validate -->|无效| Refresh{尝试刷新?}
    Refresh -->|是| RefreshToken[刷新Token]
    Refresh -->|否| Login
    RefreshToken -->|成功| SaveSession
    RefreshToken -->|失败| Login

    Validate -->|有效| CheckPermission{检查权限}
    SaveSession --> CheckPermission

    CheckPermission -->|有权限| Success([访问资源])
    CheckPermission -->|无权限| Forbidden[403禁止]

    Forbidden --> End([结束])
    Success --> End

    style Start fill:#90EE90
    style Success fill:#90EE90
    style LoginFail fill:#FFB6C1
    style Forbidden fill:#FFB6C1
    style End fill:#87CEEB

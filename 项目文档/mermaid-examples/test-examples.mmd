%% ========================================
%% 示例 3: 简单业务流程
%% ========================================
flowchart TD
    Start([开始]) --> Input[/输入数据/]
    Input --> Process[处理数据]
    Process --> Decision{数据有效?}
    Decision -->|是| Save[(保存)]
    Decision -->|否| Error[显示错误]
    Error --> Input
    Save --> End([结束])

%% ========================================
%% 示例 4: 基础子图
%% ========================================
flowchart TB
    External[外部系统] --> System

    subgraph System [内部系统]
        direction LR
        A[模块A] --> B[模块B]
        B --> C[模块C]
    end

    System --> Output[/输出/]

%% ========================================
%% 示例 5: 嵌套子图 - 电商系统
%% ========================================
flowchart TB
    User([用户]) --> Frontend

    subgraph ecommerce [电商平台]
        direction TB

        subgraph frontend [前端展示层]
            direction LR
            Web[Web端] --> Mobile[移动端]
        end

        subgraph services [服务层]
            direction TB

            subgraph user_service [用户服务]
                Auth[认证] --> Profile[个人信息]
            end

            subgraph order_service [订单服务]
                Cart[购物车] --> Checkout[结算]
                Checkout --> Payment[支付]
            end

            subgraph product_service [商品服务]
                Search[搜索] --> Detail[详情]
                Detail --> Inventory[库存]
            end
        end

        subgraph data [数据层]
            direction LR
            UserDB[(用户数据库)]
            OrderDB[(订单数据库)]
            ProductDB[(商品数据库)]
        end

        frontend --> services
        services --> data
    end

    Frontend --> Payment
    Payment --> PaymentGateway{支付网关}
    PaymentGateway --> Success([成功])
    PaymentGateway --> Fail([失败])

%% ========================================
%% 示例 6: 软件开发流程
%% ========================================
flowchart TD
    Start([开始新功能]) --> Planning

    subgraph dev_process [开发流程]
        direction TB

        Planning[需求分析] --> Design[设计方案]
        Design --> Review1{设计评审}
        Review1 -->|通过| Development
        Review1 -->|不通过| Design

        subgraph implementation [实现阶段]
            direction LR
            Development[编码] --> UnitTest[单元测试]
            UnitTest --> CodeReview{代码评审}
            CodeReview -->|需修改| Development
            CodeReview -->|通过| Integration
        end

        Integration[集成] --> QA

        subgraph testing [测试阶段]
            direction TB
            QA[QA测试] --> BugFound{发现Bug?}
            BugFound -->|是| BugFix[修复Bug]
            BugFix --> QA
            BugFound -->|否| UAT[用户验收测试]
        end

        UAT --> Final{验收通过?}
        Final -->|是| Deploy
        Final -->|否| Development
    end

    Deploy[部署上线] --> Monitor[监控]
    Monitor --> End([完成])

%% ========================================
%% 示例 7: 微服务架构
%% ========================================
flowchart TB
    Client([客户端]) --> Gateway[API网关]

    subgraph infrastructure [基础设施]
        direction TB

        Gateway --> LoadBalancer{负载均衡}

        subgraph services [微服务集群]
            direction LR

            subgraph service_a [服务A集群]
                A1[实例1] & A2[实例2] & A3[实例3]
            end

            subgraph service_b [服务B集群]
                B1[实例1] & B2[实例2]
            end

            subgraph service_c [服务C集群]
                C1[实例1] & C2[实例2]
            end
        end

        LoadBalancer --> services

        subgraph data_layer [数据层]
            direction LR
            Redis[(Redis缓存)]
            MySQL[(MySQL)]
            MongoDB[(MongoDB)]
            Kafka[/消息队列/]
        end

        services --> data_layer

        subgraph monitoring [监控系统]
            Metrics[指标采集] --> Dashboard[监控面板]
            Logs[日志收集] --> Dashboard
        end

        services -.-> monitoring
    end

